{
  "permissions": {
    "defaultMode": "auto"
  },
  "model": "claude-fable-5[1m]",
  "statusLine": {
    "type": "command",
    "command": "bash ~/bin/claude-statusline"
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": false,
    "claude-md-management@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "claude-tmux-notifier@ddzero2c": true,
    "playground@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "ddzero2c": {
      "source": {
        "source": "github",
        "repo": "ddzero2c/claude-tmux-notifier"
      }
    }
  },
  "syntaxHighlightingDisabled": false,
  "effortLevel": "low",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "theme": "light-daltonized",
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "systemPrompt": "MUST NOT write code comments. Exception: the logic is truly obscure and cannot be expressed through naming or structure."
}
