{
  "permissions": {
    "defaultMode": "auto"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/bin/tmux-notifier \"Done, waiting for input\""
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/bin/tmux-notifier \"$(jq -r '.message')\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/bin/claude-statusline"
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "github@claude-plugins-official": true
  },
  "effortLevel": "xhigh",
  "theme": "dark-daltonized",
  "skipAutoPermissionPrompt": true,
  "agentPushNotifEnabled": true,
  "inputNeededNotifEnabled": true
}
