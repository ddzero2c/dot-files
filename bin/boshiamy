#!/usr/bin/env python3
import argparse
from pathlib import Path

DICT_PATH = Path.home() / "Library/Rime/liur_Trad.dict.yaml"


def load_dict(path):
    table = {}
    started = False
    with open(path, encoding="utf-8") as f:
        for line in f:
            line = line.rstrip("\n")
            if line.strip() == "...":
                started = True
                continue
            if not started or not line.strip():
                continue
            parts = line.split("\t")
            if len(parts) < 2:
                continue
            char, code = parts[0], parts[1].lstrip("~")
            table.setdefault(char, []).append(code)
    return table


def lookup(table, char, include_short):
    codes = table.get(char)
    if not codes:
        return []
    max_len = max(len(c) for c in codes)
    codes = sorted(set(codes), key=lambda c: (-len(c), c))
    results = [(c, "建議" if len(c) == max_len else "簡") for c in codes]
    if not include_short:
        results = [r for r in results if r[1] == "建議"]
    return results


def print_table(rows):
    widths = [max(len(r[i]) for r in rows) for i in range(3)]
    for row in rows:
        print("  ".join(cell.ljust(w) for cell, w in zip(row, widths)))


def main():
    parser = argparse.ArgumentParser(description="嘸蝦米查碼工具")
    parser.add_argument("chars", nargs="+", help="要查詢的字")
    parser.add_argument("-s", "--short", action="store_true", help="同時顯示簡碼")
    args = parser.parse_args()

    if not DICT_PATH.exists():
        print(f"找不到字碼表: {DICT_PATH}")
        raise SystemExit(1)

    table = load_dict(DICT_PATH)
    query = "".join(args.chars)

    rows = []
    for char in query:
        results = lookup(table, char, args.short)
        if not results:
            rows.append((char, "-", "查無此字"))
        else:
            for code, tag in results:
                rows.append((char, code.upper(), tag))

    print_table(rows)


if __name__ == "__main__":
    main()
