#!/usr/bin/env bash
# Usage: tmux-sessionizer [path [init_cmd]]
#   path      directory to open as a session; omit to pick with fzf
#   init_cmd  command typed into the new session after creation

if [[ $# -ge 1 ]]; then
    selected=$1
    init_cmd=$2
else
    selected=$(find ~/repo ~/repo/*/.claude/worktrees -mindepth 1 -maxdepth 1 -type d 2>/dev/null | fzf)
fi

if [[ -z $selected ]]; then
    exit 0
fi

session_name=$(basename "$selected" | tr . _)

has_session() {
    tmux list-sessions -F '#S' 2>/dev/null | grep -qFx "$1"
}

switch_to() {
    if [[ -z $TMUX ]]; then
        tmux attach-session -t "$1"
    else
        tmux switch-client -t "$1"
    fi
}

if ! has_session "$session_name"; then
    tmux new-session -ds "$session_name" -c "$selected"
    [[ -n $init_cmd ]] && tmux send-keys -t "$session_name" "$init_cmd" Enter
fi

switch_to "$session_name"
