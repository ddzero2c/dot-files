#!/usr/bin/env bash

set -e
trap 'echo ""; echo "Failed. Press any key to close."; read -n 1' ERR

action="$1"

repo_root=$(git rev-parse --show-toplevel 2>/dev/null)

if [[ $action == "add" ]]; then
	branch_name="$2"
	if [[ -z $branch_name ]]; then
		exit 0
	fi
fi

if [[ -z $repo_root ]]; then
	echo "Not a git repository"
	exit 1
fi

dir_name=$(echo "$branch_name" | tr '/' '-')
worktree_path="$repo_root/.claude/worktrees/$dir_name"

if [[ $action == "add" ]]; then
	if [[ -d $worktree_path ]]; then
		~/bin/tmux-sessionizer "$worktree_path"
		exit 0
	fi

	if git -C "$repo_root" show-ref --verify --quiet "refs/heads/$branch_name"; then
		echo "Checking out existing branch $branch_name..."
		git -C "$repo_root" worktree add "$worktree_path" "$branch_name"
	elif git -C "$repo_root" show-ref --verify --quiet "refs/remotes/origin/$branch_name"; then
		start_point="origin/$branch_name"
		echo "Creating branch from origin/$branch_name..."
	else
		default_branch=$(git -C "$repo_root" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@')
		if [[ -z $default_branch ]]; then
			default_branch="main"
		fi
		start_point="origin/$default_branch"
		echo "Creating branch from origin/$default_branch..."
	fi
	if [[ -n $start_point ]]; then
		git -C "$repo_root" worktree add "$worktree_path" -b "$branch_name" "$start_point"
		git -C "$repo_root" branch --unset-upstream "$branch_name" 2>/dev/null || true
	fi

	# Copy .env files (supports monorepo)
	cd "$repo_root"
	find . -maxdepth 2 -name '.env' -not -path './.git/*' | while read -r envfile; do
		target="$worktree_path/$envfile"
		mkdir -p "$(dirname "$target")"
		cp "$envfile" "$target"
	done
	~/bin/tmux-sessionizer "$worktree_path" "claude"

elif [[ $action == "remove" ]]; then
	worktree_dir="$repo_root/.claude/worktrees"
	if [[ ! -d $worktree_dir ]]; then
		exit 0
	fi

	selected=$(find "$worktree_dir" -mindepth 1 -maxdepth 1 -type d | sed "s|$worktree_dir/||" | fzf)
	if [[ -z $selected ]]; then
		exit 0
	fi

	selected_path="$worktree_dir/$selected"
	session_name=$(echo "$selected" | tr . _)

	# Remove worktree and branch
	git -C "$repo_root" worktree remove "$selected_path" --force
	git -C "$repo_root" branch -D "$selected" 2>/dev/null || true

	# Kill session and switch back
	tmux kill-session -t "$session_name" 2>/dev/null || true
fi
