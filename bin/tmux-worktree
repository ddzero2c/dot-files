#!/usr/bin/env bash
# Usage: tmux-worktree add <branch> | remove
#   add     create (or reuse) a worktree for <branch> under <repo>/.claude/worktrees,
#           copy .env files from the main checkout, open a tmux session running claude
#   remove  pick a worktree with fzf, then delete the worktree, its branch and tmux session

set -e
trap 'echo ""; echo "Failed. Press any key to close."; read -rn 1' ERR

repo_root=$(git rev-parse --show-toplevel 2>/dev/null)
if [[ -z $repo_root ]]; then
	echo "Not a git repository"
	exit 1
fi

worktrees_dir="$repo_root/.claude/worktrees"

git_repo() {
	git -C "$repo_root" "$@"
}

branch_exists() {
	git_repo show-ref --verify --quiet "$1"
}

default_branch() {
	local branch
	branch=$(git_repo symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@')
	echo "${branch:-main}"
}

create_worktree() {
	local branch=$1 path=$2

	if branch_exists "refs/heads/$branch"; then
		echo "Checking out existing branch $branch..."
		git_repo worktree add "$path" "$branch"
		return
	fi

	local start_point
	if branch_exists "refs/remotes/origin/$branch"; then
		start_point="origin/$branch"
	else
		start_point="origin/$(default_branch)"
	fi
	echo "Creating branch from $start_point..."
	git_repo worktree add "$path" -b "$branch" "$start_point"
	git_repo branch --unset-upstream "$branch" 2>/dev/null || true
}

copy_env_files() {
	local dest=$1
	(cd "$repo_root" && find . -maxdepth 2 -name '.env' -not -path './.git/*') |
		while read -r envfile; do
			mkdir -p "$dest/$(dirname "$envfile")"
			cp "$repo_root/$envfile" "$dest/$envfile"
		done
}

add() {
	local branch=$1
	if [[ -z $branch ]]; then
		exit 0
	fi

	local path="$worktrees_dir/$(echo "$branch" | tr '/' '-')"
	if [[ ! -d $path ]]; then
		create_worktree "$branch" "$path"
		copy_env_files "$path"
	fi
	~/bin/tmux-sessionizer "$path" "claude"
}

remove() {
	if [[ ! -d $worktrees_dir ]]; then
		exit 0
	fi

	local selected
	selected=$(find "$worktrees_dir" -mindepth 1 -maxdepth 1 -type d | sed "s|$worktrees_dir/||" | fzf)
	if [[ -z $selected ]]; then
		exit 0
	fi

	local path="$worktrees_dir/$selected"
	local branch
	branch=$(git -C "$path" branch --show-current)

	git_repo worktree remove "$path" --force
	if [[ -n $branch ]]; then
		git_repo branch -D "$branch" 2>/dev/null || true
	fi
	tmux kill-session -t "$(echo "$selected" | tr . _)" 2>/dev/null || true
}

case "$1" in
add) add "$2" ;;
remove) remove ;;
*)
	echo "Usage: tmux-worktree add <branch> | remove"
	exit 1
	;;
esac
